<%- include('../partials/head', { title }) %>
    <%- include('../partials/nav') %>
        <div class="container-fluid px-4 pb-4">
            <%- include('../partials/flashes') %>
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h4 class="mb-0">PO Tracking List</h4>
                    <a class="btn btn-primary" href="/po-tracking/create">Create New Customer PO Tracking</a>
                </div>

                <div class="card">
                    <div class="card-body table-responsive">
                        <table class="table table-striped table-bordered js-datatable">
                            <thead>
                                <tr>
                                    <th>Customer PO No</th>
                                    <th>Customer</th>
                                    <th>Receive Date</th>
                                    <th>Delivery Due</th>
                                    <th>Status</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% rows.forEach((row)=> { %>
                                    <tr>
                                        <td>
                                            <%= row.customer_po_no %>
                                        </td>
                                        <td>
                                            <%= row.customer_name %>
                                        </td>
                                        <td>
                                            <%= new Date(row.receive_date).toISOString().slice(0, 10) %>
                                        </td>
                                        <td>
                                            <%= new Date(row.delivery_due_date).toISOString().slice(0, 10) %>
                                        </td>
                                        <td><span
                                                class="badge <%= row.status === 'completed' ? 'bg-success' : 'bg-warning text-dark' %>">
                                                <%= row.status %>
                                            </span></td>
                                        <td class="d-flex gap-1">
                                            <a href="/po-tracking/<%= row.id %>/view"
                                                class="btn btn-sm btn-info text-white">View</a>
                                            <a href="/po-tracking/<%= row.id %>/edit"
                                                class="btn btn-sm btn-primary">Edit</a>
                                            <% if (currentUser.role==='system_admin' ) { %>
                                                <form method="post" action="/po-tracking/<%= row.id %>/delete"
                                                    onsubmit="return confirm('Delete this record?')">
                                                    <button class="btn btn-sm btn-danger">Delete</button>
                                                </form>
                                                <% } %>
                                        </td>
                                    </tr>
                                    <% }) %>
                            </tbody>
                        </table>
                    </div>
                </div>
        </div>
        <%- include('../partials/footer') %>