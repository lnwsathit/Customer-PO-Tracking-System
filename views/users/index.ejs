<%- include('../partials/head', { title }) %>
    <%- include('../partials/nav') %>
        <div class="container-fluid px-4 pb-4">
            <%- include('../partials/flashes') %>
                <h4 class="mb-3">User List</h4>

                <div class="card mb-4">
                    <div class="card-header">Create User</div>
                    <div class="card-body">
                        <form action="/users" method="post" class="row g-2">
                            <div class="col-md-2"><input name="username" class="form-control" placeholder="Username"
                                    required /></div>
                            <div class="col-md-2"><input name="password" type="password" class="form-control"
                                    placeholder="Password" required /></div>
                            <div class="col-md-3"><input name="name" class="form-control" placeholder="Name Lastname"
                                    required /></div>
                            <div class="col-md-2"><select name="role" class="form-select">
                                    <option value="data_entry">data_entry</option>
                                    <option value="data_manager">data_manager</option>
                                    <option value="system_admin">system_admin</option>
                                </select></div>
                            <div class="col-md-2"><select class="form-select" name="status">
                                    <option value="active">active</option>
                                    <option value="inactive">inactive</option>
                                </select></div>
                            <div class="col-md-1"><button class="btn btn-primary w-100">Save</button></div>
                        </form>
                    </div>
                </div>

                <div class="card">
                    <div class="card-body table-responsive">
                        <table class="table table-striped table-bordered js-datatable">
                            <thead>
                                <tr>
                                    <th>Username</th>
                                    <th>Full Name</th>
                                    <th>Role</th>
                                    <th>Status</th>
                                    <th>Created</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% rows.forEach((row)=> { %>
                                    <tr>
                                        <td>
                                            <%= row.username %>
                                        </td>
                                        <td>
                                            <%= row.name %>
                                        </td>
                                        <td>
                                            <%= row.role %>
                                        </td>
                                        <td>
                                            <%= row.status %>
                                        </td>
                                        <td>
                                            <%= new Date(row.created_at).toISOString().slice(0,10) %>
                                        </td>
                                        <td>
                                            <div class="d-flex gap-1">
                                                <a href="/users/<%= row.id %>/view"
                                                    class="btn btn-sm btn-info text-white">View</a>
                                                <a href="/users/<%= row.id %>/edit"
                                                    class="btn btn-sm btn-primary">Edit</a>
                                                <form action="/users/<%= row.id %>/delete" method="post"
                                                    onsubmit="return confirm('Delete user?')">
                                                    <button class="btn btn-sm btn-danger">Delete</button>
                                                </form>
                                            </div>
                                        </td>
                                    </tr>
                                    <% }) %>
                            </tbody>
                        </table>
                    </div>
                </div>
        </div>
        <%- include('../partials/footer') %>