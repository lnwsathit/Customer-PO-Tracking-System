<%- include('../partials/head', { title }) %>
    <div class="container py-4">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h2 class="mb-0">Customer PO Tracking System</h2>
            <a href="/login" class="btn btn-outline-primary">Login</a>
        </div>

        <div class="card mb-4">
            <div class="card-body">
                <form action="/search" method="get" class="row g-2">
                    <div class="col-md-10">
                        <input type="text" name="q" class="form-control"
                            placeholder="Search by Customer PO No, Quotation No, Customer Name" value="<%= q || '' %>"
                            required />
                    </div>
                    <div class="col-md-2 d-grid">
                        <button class="btn btn-primary" type="submit">Search</button>
                    </div>
                </form>
            </div>
        </div>

        <% if (hasSearched) { %>
            <div class="card">
                <div class="card-header">Search Result</div>
                <div class="card-body table-responsive">
                    <% if (results.length) { %>
                        <table class="table table-striped table-bordered js-datatable">
                            <thead>
                                <tr>
                                    <th>Customer PO No</th>
                                    <th>Customer Name</th>
                                    <th>Receive Date</th>
                                    <th>Status</th>
                                    <th>View</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% results.forEach((row)=> { %>
                                    <tr>
                                        <td>
                                            <%= row.customer_po_no %>
                                        </td>
                                        <td>
                                            <%= row.customer_name %>
                                        </td>
                                        <td>
                                            <%= new Date(row.receive_date).toISOString().slice(0, 10) %>
                                        </td>
                                        <td>
                                            <span
                                                class="badge <%= row.status === 'completed' ? 'bg-success' : 'bg-warning text-dark' %>">
                                                <%= row.status %>
                                            </span>
                                        </td>
                                        <td><a class="btn btn-sm btn-primary" href="/tracking/<%= row.id %>">View</a>
                                        </td>
                                    </tr>
                                    <% }) %>
                            </tbody>
                        </table>
                        <% } else { %>
                            <div class="text-muted">No matching records found.</div>
                            <% } %>
                </div>
            </div>
            <% } %>
    </div>
    <%- include('../partials/footer') %>