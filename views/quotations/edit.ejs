<%- include('../partials/head', { title }) %>
    <%- include('../partials/nav') %>
        <div class="container py-4">
            <h4>Edit Quotation</h4>
            <div class="card">
                <div class="card-body">
                    <form action="/quotations/<%= row.id %>/update" method="post" enctype="multipart/form-data"
                        class="row g-2">
                        <div class="col-md-6"><label class="form-label">Customer Name</label><select class="form-select"
                                name="bst_customer_id" required>
                                <% customers.forEach((c)=>{ %><option value="<%= c.id %>" <%=row.bst_customer_id===c.id
                                        ? 'selected' : '' %>><%= c.name %>
                                    </option>
                                    <% }) %>
                            </select></div>
                        <div class="col-md-6"><label class="form-label">Quotation No</label><input
                                name="bst_quotation_no" class="form-control" value="<%= row.bst_quotation_no %>"
                                required /></div>
                        <div class="col-md-4"><label class="form-label">Quotation Date</label><input type="date"
                                name="bst_quotation_date" class="form-control"
                                value="<%= new Date(row.bst_quotation_date).toISOString().slice(0,10) %>" required />
                        </div>
                        <div class="col-md-4"><label class="form-label">PDF</label><input type="file"
                                name="quotation_file" accept="application/pdf" class="form-control" /></div>
                        <div class="col-md-4"><label class="form-label">Status</label><select class="form-select"
                                name="status">
                                <option value="active" <%=row.status==='active' ? 'selected' : '' %>>active</option>
                                <option value="inactive" <%=row.status==='inactive' ? 'selected' : '' %>>inactive
                                </option>
                            </select></div>
                        <div class="col-12"><label class="form-label">Detail</label><input name="detail"
                                class="form-control" value="<%= row.detail || '' %>" /></div>
                        <div class="col-12 d-flex gap-2"><button class="btn btn-primary">Save</button><a
                                href="/quotations" class="btn btn-secondary">Back</a></div>
                    </form>
                </div>
            </div>
        </div>
        <%- include('../partials/footer') %>