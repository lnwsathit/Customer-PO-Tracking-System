<%- include('../partials/head', { title }) %>
    <%- include('../partials/nav') %>
        <div class="container-fluid px-4 pb-4">
            <%- include('../partials/flashes') %>
                <h4 class="mb-3">BST Quotation List</h4>

                <div class="card mb-4">
                    <div class="card-header">Create New Quotation</div>
                    <div class="card-body">
                        <form action="/quotations" method="post" enctype="multipart/form-data" class="row g-2">
                            <div class="col-md-3"><select class="form-select" name="bst_customer_id" required>
                                    <% customers.forEach((c)=>{ %><option value="<%= c.id %>">
                                            <%= c.name %>
                                        </option>
                                        <% }) %>
                                </select></div>
                            <div class="col-md-2"><input name="bst_quotation_no" class="form-control"
                                    placeholder="Quotation No" required /></div>
                            <div class="col-md-2"><input type="date" name="bst_quotation_date" class="form-control"
                                    required /></div>
                            <div class="col-md-2"><input type="file" name="quotation_file" accept="application/pdf"
                                    class="form-control" /></div>
                            <div class="col-md-2"><select class="form-select" name="status">
                                    <option value="active">active</option>
                                    <option value="inactive">inactive</option>
                                </select></div>
                            <div class="col-md-1"><button class="btn btn-primary w-100">Save</button></div>
                            <div class="col-12"><input name="detail" class="form-control" placeholder="Detail" /></div>
                        </form>
                    </div>
                </div>

                <div class="card">
                    <div class="card-body table-responsive">
                        <table class="table table-striped table-bordered js-datatable">
                            <thead>
                                <tr>
                                    <th>No</th>
                                    <th>Customer</th>
                                    <th>Date</th>
                                    <th>Status</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% rows.forEach((row)=> { %>
                                    <tr>
                                        <td>
                                            <%= row.bst_quotation_no %>
                                        </td>
                                        <td>
                                            <%= row.customer_name %>
                                        </td>
                                        <td>
                                            <%= new Date(row.bst_quotation_date).toISOString().slice(0,10) %>
                                        </td>
                                        <td>
                                            <%= row.status %>
                                        </td>
                                        <td>
                                            <div class="d-flex gap-1">
                                                <a href="/quotations/<%= row.id %>/view"
                                                    class="btn btn-sm btn-info text-white">View</a>
                                                <a href="/quotations/<%= row.id %>/edit"
                                                    class="btn btn-sm btn-primary">Edit</a>
                                                <form class="d-flex gap-1" action="/quotations/<%= row.id %>/delete"
                                                    method="post" onsubmit="return confirm('Delete quotation?')">
                                                    <button class="btn btn-sm btn-danger">Delete</button>
                                                </form>
                                            </div>
                                        </td>
                                    </tr>
                                    <% }) %>
                            </tbody>
                        </table>
                    </div>
                </div>
        </div>
        <%- include('../partials/footer') %>